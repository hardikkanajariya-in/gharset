# ===============================
# GharSet environment configuration
# Copy this file to .env.local before running locally.
# ===============================

# Public site config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=GharSet
NEXT_PUBLIC_BRAND_TAGLINE=Smart organizers for every Indian home.
NEXT_PUBLIC_SUPPORT_EMAIL=support@gharset.in
NEXT_PUBLIC_BUSINESS_CITY=India
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Keep true for local testing without Google credentials.
# Set to false when Google Sheets/Drive are configured.
USE_SAMPLE_DATA=true

# Google service account credentials.
# The same service account must be shared on the product and order spreadsheets.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheets IDs
PRODUCTS_SPREADSHEET_ID=
ORDERS_SPREADSHEET_ID=

# Sheet tab/range names
PRODUCTS_RANGE=Products!A:Z
CATEGORIES_RANGE=Categories!A:Z
BUNDLES_RANGE=Bundles!A:Z
SETTINGS_RANGE=Settings!A:B
ORDERS_RANGE=Orders!A:Z
LEADS_RANGE=Leads!A:Z

# Optional behavior
REVALIDATE_SECRET=change-this-secret
IMAGE_CACHE_SECONDS=86400
PRODUCT_CACHE_SECONDS=900
ORDER_TRACKING_ENABLED=true

# If true, the Drive image route tries a public Drive URL when service credentials are missing.
# Recommended only for MVP testing with public/shared images.
GOOGLE_DRIVE_PUBLIC_FALLBACK=true
